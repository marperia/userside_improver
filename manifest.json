{
  "manifest_version": 2,
  "name": "Userside Improver",
  "version": "1.0",
  "description": "Extracts IPs with ports and add some copy-paste buttons to the Userside interface",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png"
  },
  "permissions": [
    "activeTab",
    "clipboardWrite",
    "clipboardRead"
  ],
  "content_scripts": [
    {
      "matches": ["http://userside.piramida.local/*", "https://userside.piramida.local/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end"
    }
  ]
}